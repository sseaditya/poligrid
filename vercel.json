{
  "version": 2,
  "functions": {
    "api/route.js": {
      "maxDuration": 300
    }
  },
  "routes": [
    { "src": "^/api/(.*)", "dest": "/api/route" },
    { "src": "^/login$", "dest": "/login.html" },
    { "src": "^/index$", "dest": "/index.html" },
    { "src": "^/(homepage|projects|project|audit|profile|designer|designer_home|lead_designer_home|admin|admin_home|ceo)$", "dest": "/index.html" },
    { "src": "^/profile/(.*)$", "dest": "/index.html" },
    { "src": "^/sales/(.*)$", "dest": "/index.html" },
    { "src": "^/$", "dest": "/index.html" }
  ]
}
