{
  "version": 2,
  "functions": {
    "api/route.js": {
      "maxDuration": 300
    }
  },
  "routes": [
    { "src": "^/api/(.*)",      "dest": "/api/route" },
    { "src": "^/sales/(.*)",    "dest": "/sales.html" },
    { "src": "^/profile/(.*)", "dest": "/profile.html" },
    { "src": "^/login$",        "dest": "/login.html" },
    { "src": "^/homepage$",     "dest": "/homepage.html" },
    { "src": "^/projects$",     "dest": "/projects.html" },
    { "src": "^/project$",      "dest": "/project.html" },
    { "src": "^/audit$",        "dest": "/audit.html" },
    { "src": "^/index$",        "dest": "/index.html" },
    { "src": "^/designer$",     "dest": "/designer.html" },
    { "src": "^/lead_designer_home$", "dest": "/lead_designer_home.html" },
    { "src": "^/designer_home$",     "dest": "/designer_home.html" },
    { "src": "^/admin$",        "dest": "/admin.html" },
    { "src": "^/ceo$",          "dest": "/ceo.html" },
    { "src": "^/$",             "dest": "/login.html" }
  ]
}
